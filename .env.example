# OpenEtruscan Configuration
# Copy this to .env and fill in your values.

# Database URL (leave empty for local SQLite — default, zero-config)
# SQLite:      sqlite:///data/corpus.db
# PostgreSQL:  postgresql://user:password@host:5432/corpus
DATABASE_URL=

# Cloud SQL (OpenEtruscan public corpus)
# DATABASE_URL=postgresql://corpus_reader:openetruscan_readonly_2024@34.76.146.115/corpus

# Image storage directory (default: data/images/)
IMAGES_DIR=data/images
