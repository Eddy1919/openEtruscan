              "description": "Longitude of center point",
              "title": "Lon"
            },
            "description": "Longitude of center point"
          },
          {
            "name": "radius_km",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "maximum": 500,
              "minimum": 0.1,
              "description": "Radius in kilometers",
              "default": 50.0,
              "title": "Radius Km"
            },
            "description": "Radius in kilometers"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 500,
              "minimum": 1,
              "default": 100,
