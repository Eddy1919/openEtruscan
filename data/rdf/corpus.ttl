# === Classification Vocabulary ===

oevocab:funerary a skos:Concept ;
    skos:prefLabel "funerary"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:votive a skos:Concept ;
    skos:prefLabel "votive"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:dedicatory a skos:Concept ;
    skos:prefLabel "dedicatory"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:legal a skos:Concept ;
    skos:prefLabel "legal"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:commercial a skos:Concept ;
    skos:prefLabel "commercial"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:boundary a skos:Concept ;
    skos:prefLabel "boundary"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:ownership a skos:Concept ;
    skos:prefLabel "ownership"@en ;
    skos:inScheme oevocab:InscriptionClassification .

oevocab:InscriptionClassification a skos:ConceptScheme ;
    dc:title "OpenEtruscan Inscription Classification"@en .

