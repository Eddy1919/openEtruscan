    dc:identifier "CODEX_LL_VI" ;
    lawd:hasText "ciz vacl θesan flerχva neθśrac hupniś zaθrumiś flerχva neθśrac śuci eiser śic śeuc tuθiu zilci vacl lauχumneti śacnicla θesan hupniś zaθrumiś flerχva neθśrac cilθcvi hupniś zaθrumiś"@xet ;
